  "mailer_notifications_password_changed_enabled": true,
  "mailer_subjects_confirmation": "Confirm your PSG Advantage email",
  "mailer_templates_confirmation_content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Confirm your PSG Advantage email</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#FAF8F5;color:#2A2826;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FAF8F5;margin:0;padding:32px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:620px;background:#FFFFFF;border:1px solid #E4DED5;\">\n            <tr>\n              <td style=\"padding:32px 32px 20px;border-bottom:1px solid #E4DED5;\">\n                <p style=\"margin:0 0 10px;font-size:12px;line-height:1.4;text-transform:uppercase;color:#B8483E;font-weight:700;\">Phoenix Solutions Group</p>\n                <h1 style=\"margin:0;color:#1E3A52;font-size:28px;line-height:1.2;font-weight:400;\">Confirm your email.</h1>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:28px 32px 32px;\">\n                <p style=\"margin:0 0 18px;font-size:16px;line-height:1.65;color:#2A2826;\">Confirm this email address to finish setting up PSG Advantage access.</p>\n                <p style=\"margin:0 0 28px;font-size:15px;line-height:1.65;color:#4A4257;\">This link verifies that this email address belongs to you.</p>\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"background:#1E3A52;border:1px solid #1E3A52;\">\n                      <a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:13px 20px;color:#FFFFFF;text-decoration:none;font-size:14px;line-height:1.2;font-weight:700;\">Confirm email</a>\n                    </td>\n                  </tr>\n                </table>\n                <p style=\"margin:28px 0 0;font-size:13px;line-height:1.65;color:#9A958E;\">If the button does not work, paste this link into your browser:<br><a href=\"{{ .ConfirmationURL }}\" style=\"color:#B8483E;word-break:break-all;\">{{ .ConfirmationURL }}</a></p>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:18px 32px;background:#F2EEE8;border-top:1px solid #E4DED5;\">\n                <p style=\"margin:0;font-size:12px;line-height:1.6;color:#4A4257;\">PSG Advantage Portal</p>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>\n",
  "mailer_subjects_invite": "You have been invited to PSG Advantage",
  "mailer_templates_invite_content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>You have been invited to PSG Advantage</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#FAF8F5;color:#2A2826;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FAF8F5;margin:0;padding:32px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:620px;background:#FFFFFF;border:1px solid #E4DED5;\">\n            <tr>\n              <td style=\"padding:32px 32px 20px;border-bottom:1px solid #E4DED5;\">\n                <p style=\"margin:0 0 10px;font-size:12px;line-height:1.4;text-transform:uppercase;color:#B8483E;font-weight:700;\">Phoenix Solutions Group</p>\n                <h1 style=\"margin:0;color:#1E3A52;font-size:28px;line-height:1.2;font-weight:400;\">You have been invited.</h1>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:28px 32px 32px;\">\n                <p style=\"margin:0 0 18px;font-size:16px;line-height:1.65;color:#2A2826;\">You have been invited to access PSG Advantage.</p>\n                <p style=\"margin:0 0 28px;font-size:15px;line-height:1.65;color:#4A4257;\">Accept the invitation to create your portal access and view the dashboard.</p>\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"background:#1E3A52;border:1px solid #1E3A52;\">\n                      <a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:13px 20px;color:#FFFFFF;text-decoration:none;font-size:14px;line-height:1.2;font-weight:700;\">Accept invitation</a>\n                    </td>\n                  </tr>\n                </table>\n                <p style=\"margin:28px 0 0;font-size:13px;line-height:1.65;color:#9A958E;\">If the button does not work, paste this link into your browser:<br><a href=\"{{ .ConfirmationURL }}\" style=\"color:#B8483E;word-break:break-all;\">{{ .ConfirmationURL }}</a></p>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:18px 32px;background:#F2EEE8;border-top:1px solid #E4DED5;\">\n                <p style=\"margin:0;font-size:12px;line-height:1.6;color:#4A4257;\">PSG Advantage Portal</p>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>\n",
  "mailer_subjects_magic_link": "Your PSG Advantage sign-in link",
  "mailer_templates_magic_link_content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Your PSG Advantage sign-in link</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#FAF8F5;color:#2A2826;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FAF8F5;margin:0;padding:32px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:620px;background:#FFFFFF;border:1px solid #E4DED5;\">\n            <tr>\n              <td style=\"padding:32px 32px 20px;border-bottom:1px solid #E4DED5;\">\n                <p style=\"margin:0 0 10px;font-size:12px;line-height:1.4;text-transform:uppercase;color:#B8483E;font-weight:700;\">Phoenix Solutions Group</p>\n                <h1 style=\"margin:0;color:#1E3A52;font-size:28px;line-height:1.2;font-weight:400;\">Sign in to PSG Advantage.</h1>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:28px 32px 32px;\">\n                <p style=\"margin:0 0 18px;font-size:16px;line-height:1.65;color:#2A2826;\">Use this secure link to sign in to your PSG Advantage account.</p>\n                <p style=\"margin:0 0 28px;font-size:15px;line-height:1.65;color:#4A4257;\">If you did not request this link, you can ignore this email.</p>\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"background:#1E3A52;border:1px solid #1E3A52;\">\n                      <a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:13px 20px;color:#FFFFFF;text-decoration:none;font-size:14px;line-height:1.2;font-weight:700;\">Sign in</a>\n                    </td>\n                  </tr>\n                </table>\n                <p style=\"margin:28px 0 0;font-size:13px;line-height:1.65;color:#9A958E;\">If the button does not work, paste this link into your browser:<br><a href=\"{{ .ConfirmationURL }}\" style=\"color:#B8483E;word-break:break-all;\">{{ .ConfirmationURL }}</a></p>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:18px 32px;background:#F2EEE8;border-top:1px solid #E4DED5;\">\n                <p style=\"margin:0;font-size:12px;line-height:1.6;color:#4A4257;\">PSG Advantage Portal</p>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>\n",
  "mailer_subjects_recovery": "Reset your PSG Advantage password",
  "mailer_templates_recovery_content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Reset your PSG Advantage password</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#FAF8F5;color:#2A2826;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FAF8F5;margin:0;padding:32px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:620px;background:#FFFFFF;border:1px solid #E4DED5;\">\n            <tr>\n              <td style=\"padding:32px 32px 20px;border-bottom:1px solid #E4DED5;\">\n                <p style=\"margin:0 0 10px;font-size:12px;line-height:1.4;text-transform:uppercase;color:#B8483E;font-weight:700;\">Phoenix Solutions Group</p>\n                <h1 style=\"margin:0;color:#1E3A52;font-size:28px;line-height:1.2;font-weight:400;\">Reset your password.</h1>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:28px 32px 32px;\">\n                <p style=\"margin:0 0 18px;font-size:16px;line-height:1.65;color:#2A2826;\">A password reset was requested for your PSG Advantage account.</p>\n                <p style=\"margin:0 0 28px;font-size:15px;line-height:1.65;color:#4A4257;\">Use the secure link below to choose a new password. If you did not request this, you can ignore this email.</p>\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"background:#1E3A52;border:1px solid #1E3A52;\">\n                      <a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:13px 20px;color:#FFFFFF;text-decoration:none;font-size:14px;line-height:1.2;font-weight:700;\">Reset password</a>\n                    </td>\n                  </tr>\n                </table>\n                <p style=\"margin:28px 0 0;font-size:13px;line-height:1.65;color:#9A958E;\">If the button does not work, paste this link into your browser:<br><a href=\"{{ .ConfirmationURL }}\" style=\"color:#B8483E;word-break:break-all;\">{{ .ConfirmationURL }}</a></p>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:18px 32px;background:#F2EEE8;border-top:1px solid #E4DED5;\">\n                <p style=\"margin:0;font-size:12px;line-height:1.6;color:#4A4257;\">PSG Advantage Portal</p>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>\n",
  "mailer_subjects_email_change": "Confirm your PSG Advantage email change",
  "mailer_templates_email_change_content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Confirm your PSG Advantage email change</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#FAF8F5;color:#2A2826;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FAF8F5;margin:0;padding:32px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:620px;background:#FFFFFF;border:1px solid #E4DED5;\">\n            <tr>\n              <td style=\"padding:32px 32px 20px;border-bottom:1px solid #E4DED5;\">\n                <p style=\"margin:0 0 10px;font-size:12px;line-height:1.4;text-transform:uppercase;color:#B8483E;font-weight:700;\">Phoenix Solutions Group</p>\n                <h1 style=\"margin:0;color:#1E3A52;font-size:28px;line-height:1.2;font-weight:400;\">Confirm your email change.</h1>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:28px 32px 32px;\">\n                <p style=\"margin:0 0 18px;font-size:16px;line-height:1.65;color:#2A2826;\">A request was made to change your PSG Advantage account email.</p>\n                <p style=\"margin:0 0 28px;font-size:15px;line-height:1.65;color:#4A4257;\">Confirm the change to complete the update.</p>\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"background:#1E3A52;border:1px solid #1E3A52;\">\n                      <a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:13px 20px;color:#FFFFFF;text-decoration:none;font-size:14px;line-height:1.2;font-weight:700;\">Confirm email change</a>\n                    </td>\n                  </tr>\n                </table>\n                <p style=\"margin:28px 0 0;font-size:13px;line-height:1.65;color:#9A958E;\">If the button does not work, paste this link into your browser:<br><a href=\"{{ .ConfirmationURL }}\" style=\"color:#B8483E;word-break:break-all;\">{{ .ConfirmationURL }}</a></p>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:18px 32px;background:#F2EEE8;border-top:1px solid #E4DED5;\">\n                <p style=\"margin:0;font-size:12px;line-height:1.6;color:#4A4257;\">PSG Advantage Portal</p>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>\n",
  "mailer_subjects_password_changed_notification": "Your PSG Advantage password was changed",
  "mailer_templates_password_changed_notification_content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Your PSG Advantage password was changed</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#FAF8F5;color:#2A2826;font-family:Arial,sans-serif;\">\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FAF8F5;margin:0;padding:32px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:620px;background:#FFFFFF;border:1px solid #E4DED5;\">\n            <tr>\n              <td style=\"padding:32px 32px 20px;border-bottom:1px solid #E4DED5;\">\n                <p style=\"margin:0 0 10px;font-size:12px;line-height:1.4;text-transform:uppercase;color:#B8483E;font-weight:700;\">Phoenix Solutions Group</p>\n                <h1 style=\"margin:0;color:#1E3A52;font-size:28px;line-height:1.2;font-weight:400;\">Your password was changed.</h1>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:28px 32px 32px;\">\n                <p style=\"margin:0 0 18px;font-size:16px;line-height:1.65;color:#2A2826;\">This is a security notification for your PSG Advantage account.</p>\n                <p style=\"margin:0;font-size:15px;line-height:1.65;color:#4A4257;\">If you made this change, no action is required. If you did not change your password, contact Phoenix Solutions Group immediately and reset your account password.</p>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:18px 32px;background:#F2EEE8;border-top:1px solid #E4DED5;\">\n                <p style=\"margin:0;font-size:12px;line-height:1.6;color:#4A4257;\">PSG Advantage Portal</p>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>\n"
}
