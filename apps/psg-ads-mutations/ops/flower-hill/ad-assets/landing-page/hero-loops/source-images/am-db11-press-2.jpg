        jQuery(function($) {
            const form = $('.gform_wrapper form'),
                nonce = '7292fa03d2';
            form.append('<input type="hidden" name="_wpnonce" value="' + nonce + '" />');
            form.submit(function(e) {
                var nonce_input = form.find('input[name="_wpnonce"]');
                if (nonce_input.length && nonce_input.val() !== nonce) {
                    e.preventDefault();
                    form.find('.gfield_error').removeClass('gfield_error');
                    form.find('.gfield_error_message').remove();
                    form.find('input[name="_wpnonce"]').parent().addClass('gfield_error');
                    form.find('input[name="_wpnonce"]').after('<div class="gfield_error_message" style="color: red;text-align: center;margin: 20px auto;">Invalid form submission. Try Again.</div>');
                }
            });
        });
    </script>
    	<script type="text/javascript">
		jQuery(document).ready(function($) {
			document.cookie = "necessary=true; path=/";
			$('#cookie-consent-form').on('submit', function(e){
				e.preventDefault();

				if ($('#measurement-consent').is(':checked')){
					document.cookie = "measurement=true; path=/";
				}

				if ($('#experience-consent').is(':checked')){
					document.cookie = "experience=true; path=/";
				}

				$('.cookie-banner').fadeOut();

			});
		})
	</script>
