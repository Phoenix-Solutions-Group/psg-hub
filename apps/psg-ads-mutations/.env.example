# Google Ads API credentials — copy to .env and fill in. Never commit .env.
# Obtain developer token: https://ads.google.com/aw/apicenter (from MCC)
# Obtain OAuth2 credentials: https://console.cloud.google.com/apis/credentials
# Obtain refresh token: run `python -m googleads.auth_bootstrap` after setting CLIENT_ID + CLIENT_SECRET

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# MCC (manager) account ID — digits only, no dashes. Required for managed accounts.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Recommended: use proto-plus message types instead of legacy protobuf.
GOOGLE_ADS_USE_PROTO_PLUS=true
