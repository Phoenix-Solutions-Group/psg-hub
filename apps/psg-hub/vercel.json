{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/semrush-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/google-ads-sync",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/ga4-sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/gsc-sync",
      "schedule": "45 6 * * *"
    },
    {
      "path": "/api/cron/ga4-dims-sync",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/perf-sync",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 5 1 * *"
    }
  ]
}
