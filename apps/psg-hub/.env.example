# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — required for review ingestion (bypasses RLS).
# Get from Supabase dashboard → Project Settings → API → service_role key.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Review platform APIs (Phase 5)
# Yelp Fusion API: https://docs.developer.yelp.com/docs/fusion-intro (max 3 reviews per business)
YELP_API_KEY=
# Google Places API: https://developers.google.com/maps/documentation/places/web-service/get-api-key
# Enable "Places API" in Google Cloud Console (max 5 reviews per place).
# Also powers smart-onboarding auto-discovery (PSG-149): website/phone/hours/
# reviews + canonical address. Paid per-field; spend is board-gated (PSG-142).
GOOGLE_PLACES_API_KEY=

# Smart-onboarding discovery provider (PSG-144 seam / PSG-149).
# "heuristic" (default, offline, zero-cost) or "google_places". When set to
# google_places but GOOGLE_PLACES_API_KEY is absent, discovery transparently
# degrades back to the heuristic provider — onboarding never fails.
ONBOARDING_DISCOVERY_PROVIDER=heuristic

# Anthropic API (Phase 5 — review response drafting)
# https://console.anthropic.com/settings/keys
# Rotate quarterly. Server-side only — never expose to the client.
ANTHROPIC_API_KEY=

# Google Ads API integration (Phase 5 — Plan 05-03)
# OAuth client (create in Google Cloud Console → Credentials → OAuth 2.0 Client ID; type=Web)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match one of the "Authorized redirect URIs" on the OAuth client.
GOOGLE_ADS_OAUTH_REDIRECT_URI=https://app.example.com/api/ads/google/callback
# Google Ads developer token (apply at ads.google.com → Tools → API Center).
# Must be Standard access for production campaigns.
GOOGLE_ADS_DEVELOPER_TOKEN=
# MCC (manager account) login_customer_id (digits only, no dashes). Leave blank if not using MCC.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Base64-encoded 32-byte AES-256 key for refresh-token encryption. Rotate annually.
# See docs/secrets.md for rotation procedure.
ADS_ENCRYPTION_KEY=
# Future rotation slot (uncomment + set before re-encrypting old rows):
# ADS_ENCRYPTION_KEY_V2=
# Random 32+ byte secret for HMAC-signing OAuth state tokens.
ADS_STATE_SECRET=
# Rate limits per shop per hour (see dashboard/src/lib/google-ads/client.ts).
ADS_MUTATE_LIMIT_PER_HOUR=20
ADS_READ_LIMIT_PER_HOUR=500
# Hard ceiling on campaign daily budget (micros; 1_000_000 micros = $1). 500_000_000 = $500/day.
ADS_MAX_DAILY_MICROS=500000000
# Comma-separated shop slugs exempt from Performance-tier gating (internal PSG shops).
SHOP_ADS_TIER_OVERRIDE=
# PSG-126 — Ads Mutation Studio high-risk EXECUTE approval allowlist.
# Comma/space-separated accepted board-confirmation UUIDs. Set ONLY by the operator/board
# in the Vercel console (NOT editable by the in-UI superadmin) so a genuine board card is
# required to run a live mutation. When set, a high-risk execute approvalId must be a member
# (fail-closed 422 otherwise). When blank, execute still requires a UUID-shaped approvalId
# (free text is always rejected) but is not resolved against accepted approvals.
ADS_MUTATIONS_APPROVAL_ALLOWLIST=

# Stripe price ids (Phase 4 Essentials/Growth, Phase 5 Performance tier).
# Create recurring prices in Stripe dashboard → Products. Required for matching tier to appear in /dashboard/billing.
STRIPE_ESSENTIALS_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_PERFORMANCE_PRICE_ID=

# SendGrid transactional email (Phase 3 — Plan 03-01).
# API key: SendGrid → Settings → API Keys (scopes: Mail Send + Event Webhook). Server-side only.
SENDGRID_API_KEY=
# Verified sender on the authenticated psgweb.me domain (Settings → Sender Authentication).
SENDGRID_FROM_EMAIL=noreply@psgweb.me
# Signed Event Webhook verification key (Settings → Mail Settings → Event Webhook → enable signature).
# Used to verify X-Twilio-Email-Event-Webhook-Signature on /api/webhooks/sendgrid.
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# Twilio SMS (Phase 3 — Plan 03-02).
# Account SID + Auth Token: Twilio Console dashboard. Server-side only.
# The Auth Token ALSO verifies inbound webhooks (HMAC-SHA1 of the request URL +
# sorted POST params) — there is NO separate webhook verification key var.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Preferred sender: a Messaging Service SID (Console → Messaging → Services; MG...).
# Wraps a sender pool + failover + opt-out/compliance. Falls back to TWILIO_PHONE_NUMBER.
TWILIO_MESSAGING_SERVICE_SID=
# Bare sender number (E.164), used only when no Messaging Service is configured.
TWILIO_PHONE_NUMBER=
# Public base URL used to reconstruct the EXACT URL Twilio signed for X-Twilio-Signature
# verification (NOT request.url — that is the internal URL behind the Vercel proxy).
# Must match the StatusCallback / inbound URL configured in the Twilio Console exactly.
# Phase-3 carry-over: wired to the real host (https://hub.psgweb.me) in 03-04.
TWILIO_WEBHOOK_BASE_URL=

# Sanity content backend (Phase 3 — Plan 03-03; D55: new PSG project).
# No client code ships this slice — these establish the env contract that v0.3 consumers
# read and that 03-04 wires into Vercel (production values set there, like SENDGRID_*/TWILIO_*).
# Project id of the NEW PSG Sanity project (provisioned in 03-03). Safe to expose client-side.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Single production dataset (D55).
NEXT_PUBLIC_SANITY_DATASET=production
# API version — pin to an ISO date; bump deliberately when adopting newer API behavior.
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
# Server-only Viewer token (Sanity → Manage → API → Tokens). Required for a PRIVATE dataset
# or reading drafts. NEVER expose to the client. Leave blank if the dataset is public.
SANITY_API_READ_TOKEN=

# Lob.com production mail (v1.3 — PSG core revenue, board gate G4).
# API key: Lob Dashboard → Settings → API Keys. A `test_*` key targets Lob test
# mode (free, no per-piece spend) and is what the build is verified against; the
# `live_*` key (and the per-piece + API spend it incurs) is gated behind board
# gate G4 and only set in prod env. Server-side only.
LOB_API_KEY=
# Webhook signing secret: Lob Dashboard → Webhooks → (endpoint) → secret.
# Verifies Lob-Signature (HMAC-SHA256 of `${timestamp}.${rawBody}`) on
# /api/webhooks/lob. Fails closed if unset.
LOB_WEBHOOK_SECRET=

# Pipedrive CRM (PSG-423 — read-only connection test; deferred feature build).
# Personal-token auth: the api_token is passed as a query param against
# https://{PIPEDRIVE_COMPANY_DOMAIN}.pipedrive.com/api/v1 — so BOTH are required.
# Server-side only, never exposed to the client, never logged.
#   PIPEDRIVE_API_TOKEN     — Pipedrive → Settings → Personal preferences → API → token.
#   PIPEDRIVE_COMPANY_DOMAIN — your account subdomain ("acme" for acme.pipedrive.com;
#                              a full host/URL is also accepted and normalized).
# NOTE: the loader also accepts the aliases PIPEDRIVE_TOKEN / PIPEDRIVE_API_KEY and
# PIPEDRIVE_DOMAIN / PIPEDRIVE_COMPANY / PIPEDRIVE_SUBDOMAIN. The EXACT name(s) set in
# Vercel (project psg-digital/psg-hub) are confirmed via GET /api/ops/crm/pipedrive/ping,
# which reports present PIPEDRIVE_* key NAMES (never values) — see INTEGRATIONS.md.
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=
# Invoiced.app external billing (PSG-422 — read-only connection test only; the
# `invoices` mirror + /api/webhooks/invoiced in PLANNING.md are NOT built yet).
# Auth is HTTP Basic with the API key as the USERNAME (empty password). Server-only.
# ⚠️ The exact var NAME Nick set in Vercel (psg-digital/psg-hub) is unconfirmed —
# `vercel env ls` was unavailable to the agent. The loader checks these names in
# order: INVOICED_API_KEY, INVOICED_SANDBOX_API_KEY, INVOICED_SECRET_KEY, INVOICED_KEY.
# The /api/ops/admin/integrations/invoiced/ping route reports which one resolved
# (`keySource`) so the deployed run confirms the real name. Once confirmed, prune to it.
INVOICED_API_KEY=
# Environment selector. Unset (or anything other than "live") = SANDBOX (no spend),
# which is where the connection test runs first. Set INVOICED_ENV=live only when the
# live account is intentionally targeted.
INVOICED_ENV=
