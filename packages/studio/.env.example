# @psg/studio — Sanity Studio environment
# Real values go in a gitignored .env.local (never commit project ids/tokens here).
# SANITY_STUDIO_* vars are the only env exposed to the studio bundle.

# New PSG Sanity project id (provisioned in Phase 3 / 03-03). Set in .env.local.
SANITY_STUDIO_PROJECT_ID=
# Single production dataset (D55).
SANITY_STUDIO_DATASET=production
